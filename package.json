{
  "name": "juce-color-picker",
  "displayName": "JUCE Color Picker",
  "description": "Shows VS Code color decorators for JUCE colour expressions in C++.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:cpp",
    "onLanguage:c"
  ],
  "main": "./out/extension.js",
  "contributes": {},
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package:vsix": "npm run compile && vsce package --allow-missing-repository",
    "install:vsix": "node ./scripts/install-vsix.js",
    "reinstall:vsix": "npm run package:vsix && npm run install:vsix",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.1",
    "@types/vscode": "^1.96.0",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.1.0",
    "typescript": "^5.8.2"
  }
}